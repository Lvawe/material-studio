# 模块② 分析配置 - 基于 claude-internal CLI（Claude Code Internal）
# 复制本文件为 .env 并填入真实值

# CodeBuddy API Key（从 CodeBuddy API Key 管理页创建获取）
# 文档：https://iwiki.woa.com/p/4015845000
CODEBUDDY_API_KEY=your-codebuddy-api-key

# claude-internal 可执行路径
# 安装：npm install -g --registry=https://mirrors.tencent.com/npm @tencent/claude-code-internal
CLAUDE_CLI_PATH=claude-internal

# 分析模式：
#   text   = 基于素材元数据+投放数据用内部文本模型生成脚本（非交互模式无视觉能力，当前默认）
#   vision = 抽帧读图分析（需要真正支持图片的视觉模型API）
ANALYSIS_MODE=text

# 主模型（text模式建议内部文本模型；vision模式需视觉模型）
LLM_MODEL=DeepSeek-V4-Pro

# 回退模型（主模型失败时自动重试）
LLM_FALLBACK_MODEL=GLM-4.7

# 单条分析超时秒数
LLM_TIMEOUT=180

# 视频URL模板：若明细只有纯MD5，用此模板拼出可下载地址（{md5} 占位）
VIDEO_URL_TEMPLATE=

# 每条视频抽帧数（仅 vision 模式生效）
FRAME_COUNT=8

# 强制使用 mock
USE_MOCK=false
