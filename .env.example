# 模块② 视频分析配置 - 基于 claude-internal CLI（Claude Code Internal）
# 复制本文件为 .env 并填入真实值

# CodeBuddy API Key（从 CodeBuddy API Key 管理页创建获取）
# 文档：https://iwiki.woa.com/p/4015845000
CODEBUDDY_API_KEY=your-codebuddy-api-key

# claude-internal 可执行路径（默认走 PATH 查找）
# 安装：npm install -g --registry=https://mirrors.tencent.com/npm @tencent/claude-code-internal
CLAUDE_CLI_PATH=claude-internal

# 单条视频分析超时秒数
LLM_TIMEOUT=180

# 视频URL模板：若明细只有 MD5，用此模板拼出可下载地址（{md5} 占位）
VIDEO_URL_TEMPLATE=

# 每条视频抽帧数
FRAME_COUNT=8

# 强制使用 mock（true 时不调用真实模型，返回示例结果）
USE_MOCK=false
