# 大模型配置（CodeBuddy / 混元 网关，OpenAI 兼容协议）
# 复制本文件为 .env 并填入真实值

# 接口地址（OpenAI 兼容网关 base url，以 /v1 结尾）
LLM_BASE_URL=https://api.codebuddy.woa.com/v1

# 多模态模型名称（需支持图片输入）
LLM_MODEL=gpt-4o

# API Key / Token
LLM_API_KEY=9f620de4cda64c5d8dbdd68990755ed6

# 抽帧数量（每条视频均匀抽取多少帧送给模型）
FRAME_COUNT=8

# 是否强制使用 mock（无网络/未配置时为 true，会返回示例分析结果）
USE_MOCK=false
